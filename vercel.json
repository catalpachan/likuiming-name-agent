{
  "version": 2,
  "framework": null,
  "builds": [
    {
      "src": "api/**/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "templates/index.html",
      "use": "static"
    }
  ],
  "routes": [
    {
      "src": "/api/calculate",
      "methods": ["POST", "OPTIONS"],
      "dest": "/api/calculate.py"
    },
    {
      "src": "/api/generate-pdf",
      "methods": ["POST", "OPTIONS"],
      "dest": "/api/generate_pdf.py"
    },
    {
      "src": "/",
      "dest": "/templates/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/templates/$1.html"
    }
  ]
}
