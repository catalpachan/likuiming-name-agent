{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "templates/**",
      "use": "static"
    },
    {
      "src": "requirements.txt",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/calculate",
      "methods": ["POST"],
      "dest": "/api/calculate.py"
    },
    {
      "src": "/api/generate-pdf",
      "methods": ["POST"],
      "dest": "/api/generate_pdf.py"
    },
    {
      "src": "/download/(.*)",
      "dest": "/api/download.py"
    },
    {
      "src": "/(.*).html",
      "dest": "/templates/$1.html"
    },
    {
      "src": "/",
      "dest": "/templates/index.html"
    }
  ]
}
