{
  "version": 2,
  "framework": null,
  "rewrites": [
    {
      "source": "/api/calculate",
      "destination": "/api/calculate.py"
    },
    {
      "source": "/api/generate-pdf",
      "destination": "/api/generate_pdf.py"
    },
    {
      "source": "/(.*)\\.html",
      "destination": "/templates/$1.html"
    },
    {
      "source": "/(.*)",
      "destination": "/templates/index.html"
    }
  ]
}
