{
  "version": 2,
  "framework": null,
  "functions": {
    "api/**/*.py": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/calculate",
      "dest": "/api/calculate.py"
    },
    {
      "src": "/api/generate-pdf",
      "dest": "/api/generate_pdf.py"
    },
    {
      "src": "/api/download/(.*)",
      "dest": "/api/download.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/",
      "dest": "/templates/index.html"
    }
  ]
}
