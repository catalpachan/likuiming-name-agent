{
  "version": 2,
  "framework": null,
  "functions": {
    "api/calculate.py": {
      "maxDuration": 60
    },
    "api/generate_pdf.py": {
      "maxDuration": 60
    },
    "api/download.py": {
      "maxDuration": 60
    }
  },
  "builds": [
    {
      "src": "templates/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/calculate",
      "dest": "/api/calculate.py"
    },
    {
      "src": "/api/generate-pdf",
      "dest": "/api/generate_pdf.py"
    },
    {
      "src": "/api/download/(.*)",
      "dest": "/api/download.py"
    },
    {
      "src": "/(.*)",
      "dest": "/templates/index.html"
    }
  ]
}
